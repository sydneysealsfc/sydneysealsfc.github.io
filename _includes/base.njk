<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title and title !== site.name %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ description }}">
  <link rel="canonical" href="{{ site.siteUrl }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{% if title and title !== site.name %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.siteUrl }}{{ page.url }}">
  <meta property="og:image" content="{{ site.siteUrl }}/images/logo.png">
  <meta property="og:site_name" content="{{ site.name }}">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{% if title and title !== site.name %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ site.siteUrl }}/images/logo.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

  <!-- Structured data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SportsClub",
    "name": "{{ site.name }}",
    "description": "{{ description }}",
    "url": "{{ site.siteUrl }}",
    "email": "{{ site.email }}",
    "logo": "{{ site.siteUrl }}/images/logo.png",
    "sameAs": [
      "{{ site.social.instagram }}",
      "{{ site.social.facebook }}"
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sydney",
      "addressRegion": "NSW",
      "addressCountry": "AU"
    },
    "sport": "Freediving"
  }
  </script>
</head>
<body>

  <!-- Skip to content -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- Navigation -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav__inner">
      <span class="nav__logo">
        <img src="/images/logo.png" alt="{{ site.name }} logo" width="52" height="52">
      </span>
      <div class="nav__links" id="navLinks" role="list">
        {% for item in site.nav %}
        <a href="{{ item.url }}" role="listitem"{% if page.url === item.url %} class="active" aria-current="page"{% endif %}>{{ item.label }}</a>
        {% endfor %}
        <a href="{{ site.teamAppUrl }}" target="_blank" rel="noopener" role="listitem">Events &amp; Merch<span class="sr-only"> (opens in new tab)</span></a>
      </div>
      <button class="nav__hamburger" id="navToggle" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="navLinks">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <main id="main-content">
    {% block content %}{% endblock %}
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer__grid">
        <div>
          <h3>Contact</h3>
          <p><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
        </div>
        <div>
          <h3>Follow us</h3>
          <div class="footer__socials">
            <a href="{{ site.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram (opens in new tab)">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="{{ site.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook (opens in new tab)">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>
        </div>
        <div>
          <h3>Quick links</h3>
          {% for item in site.nav %}
          <p><a href="{{ item.url }}">{{ item.label }}</a></p>
          {% endfor %}
          <p><a href="{{ site.teamAppUrl }}" target="_blank" rel="noopener">Events &amp; Merch</a></p>
        </div>
      </div>
      <div class="footer__aoc">
        <h3>Acknowledgement of Country</h3>
        <p>{{ site.acknowledgement }}</p>
      </div>
      <p class="footer__copy">&copy; {{ site.copyrightYear }} {{ site.name }} Inc.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
