{% extends "base.njk" %}

{% block content %}
  <!-- Page header -->
  <header class="page-header">
    <div class="container">
      <h1>{{ title }}</h1>
      {% if subtitle %}<p>{{ subtitle }}</p>{% endif %}
    </div>
  </header>

  <!-- Gallery -->
  <section class="section">
    <div class="container">
      <div class="masonry" id="galleryGrid">
        <!-- Populated from gallery.json via JavaScript -->
      </div>
      <p class="text-center" style="margin-top:2.5rem;">
        <a href="{{ site.social.instagram }}" target="_blank" rel="noopener" class="btn btn--outline">See more on Instagram</a>
      </p>
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button class="lightbox__close" id="lightboxClose" aria-label="Close">&times;</button>
    <button class="lightbox__prev" id="lightboxPrev" aria-label="Previous image">&#8249;</button>
    <button class="lightbox__next" id="lightboxNext" aria-label="Next image">&#8250;</button>
    <img class="lightbox__img" id="lightboxImg" src="" alt="">
    <p class="lightbox__credit" id="lightboxCredit"></p>
  </div>
{% endblock %}
