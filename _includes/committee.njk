{% extends "base.njk" %}

{% block content %}
  <!-- Page header -->
  <header class="page-header">
    <div class="container">
      <h1>{{ title }}</h1>
      {% if subtitle %}<p>{{ subtitle }}</p>{% endif %}
    </div>
  </header>

  <!-- Content -->
  <section class="section">
    <div class="container">
      {% if intro %}
      <p style="max-width:700px;margin:0 auto 2rem;text-align:center;color:var(--gray);">{{ intro | safe }}</p>
      {% endif %}

      <div class="committee__grid">
        {% for member in committee %}
        <div class="committee__card animate-on-scroll">
          {% if member.image %}
          <img src="/{{ member.image }}" alt="{{ member.name }}" class="committee__avatar">
          {% else %}
          <div class="committee__avatar committee__avatar--placeholder" aria-hidden="true"></div>
          {% endif %}
          <p class="committee__name">{{ member.name }}</p>
          <p class="committee__role">{{ member.role }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>
{% endblock %}
