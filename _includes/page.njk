{% extends "base.njk" %}

{% block content %}
  <!-- Page header -->
  <header class="page-header">
    <div class="container">
      <h1>{{ title }}</h1>
      {% if subtitle %}<p>{{ subtitle }}</p>{% endif %}
    </div>
  </header>

  {% if pageImage %}
  <div class="page-hero">
    <img src="/{{ pageImage }}" alt="{{ pageImageAlt }}" class="page-hero__img">
  </div>
  {% endif %}

  <!-- Content -->
  <section class="section">
    <div class="container about-page__content animate-on-scroll">
      {{ content | safe }}
    </div>
  </section>
{% endblock %}
